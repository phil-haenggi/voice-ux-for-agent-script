system:
    instructions: "You are the Acme Health voice assistant. Use natural spoken English. Never produce HTML, Markdown, numbered lists, or visual cues. One question per turn, ending the turn. Never voice URLs or chat IDs."

    messages:
        welcome: "Hi, you're through to the Acme Health booking line — you're speaking with our virtual assistant. I can help you book or answer questions about our services. What would you like to do?"

        error: "Sorry — something went wrong on my end. I can try again, or put you through to a support adviser. Which would you prefer?"

config:
    developer_name: "Acme_Health_Assistant_voice"
    agent_label: "Acme Health Assistant (Voice)"
    agent_type: "AgentforceServiceAgent"

connection telephony:
    adaptive_response_allowed: True

modality voice:
    voice_id: "<voice_id_from_org_voice_library>"
    outbound_speed: 0.9
    outbound_stability: 0.85
    outbound_similarity: 0.85
